# Waypoint environment variables.
#
# Set these in your hosting provider's dashboard (Netlify Site settings →
# Environment variables). Do NOT commit a populated `.env` file — `.env`
# is gitignored at the repo root.
#
# This file mirrors what `functions/config.js` reads at boot and what each
# Netlify function in `functions/` consumes at runtime. See `README.md` for
# the human-readable explanation of what each key buys you and where to
# get one.

# ============================================================
# REQUIRED
# ============================================================

# One of: prod, stage, demo
# Drives Demo-mode UI (read-only, Scout hidden, edits blocked).
# Anything else (or unset) is treated as "unknown" and prints a console
# warning at boot but otherwise lets the dashboard render.
WAYPOINT_ENV=prod

# Supabase project connection. The Netlify Supabase integration sets one
# of two pairs depending on integration version. `functions/config.js`
# accepts either pair — set whichever yours provides:
#   SUPABASE_URL              + SUPABASE_ANON_KEY    (older integrations)
#   SUPABASE_DATABASE_URL     + SUPABASE_PUBLISHABLE_KEY  (newer)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Fallback names — set ONLY if your integration uses these instead.
# SUPABASE_DATABASE_URL=
# SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_KEY=

# Service-role key. Required by Netlify functions (scout-background,
# scout-apollo-phone-webhook, hill-sync) for RLS-bypass writes.
# NEVER expose this to the browser — functions only.
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# OPTIONAL — Scout (LLM-driven contact research agent)
# ============================================================
# Without ANTHROPIC_API_KEY, the Scout tab is hidden entirely (graceful
# degradation), and any direct hit to /.netlify/functions/scout returns
# 503 "scout_disabled". Scout works without the other keys but with
# thinner output (no email/phone enrichment, no SAM.gov confirmation,
# no DVIDS news context).

# Required for any Scout functionality. Get at console.anthropic.com
ANTHROPIC_API_KEY=

# Optional overrides — default model is claude-sonnet-4-5 for the main
# loop and claude-haiku-4-5-20251001 for cheap title generation.
# ANTHROPIC_MODEL=
# ANTHROPIC_TITLE_MODEL=

# Apollo email + phone enrichment. Paid plan required. ~1 credit per
# matched contact for email; mobile phone reveals consume additional
# credits and are returned asynchronously via webhook.
# Get at developer.apollo.io
# APOLLO_API_KEY=

# Set to "1" to enable async mobile/direct phone reveal via Apollo's
# webhook. Requires APOLLO_WEBHOOK_URL + APOLLO_WEBHOOK_TOKEN below.
# APOLLO_REVEAL_PHONE=

# Set to "1" to fetch personal emails (costs extra credits).
# APOLLO_REVEAL_PERSONAL_EMAILS=

# Required only if APOLLO_REVEAL_PHONE=1. The public URL Apollo will
# POST phone-reveal results to. MUST end in the literal query string
# ?token=<APOLLO_WEBHOOK_TOKEN> for the webhook to authorize the call.
# Example:
#   https://your-site.netlify.app/.netlify/functions/scout-apollo-phone-webhook?token=01HXYZ...
# APOLLO_WEBHOOK_URL=

# Shared secret the webhook compares against the ?token= query. Pick
# any sufficiently long random string (UUID is fine). Required when
# APOLLO_REVEAL_PHONE=1.
# APOLLO_WEBHOOK_TOKEN=

# Set to "1" to echo Apollo's parsed payload back in the webhook's 200
# response. Dev/debug only — never set in production (leaks Apollo data).
# APOLLO_WEBHOOK_DEBUG=

# Federal contracts confirmation tool. Hard daily rate limit.
# Get at sam.gov/data-services (free).
# SAM_GOV_API_KEY=

# Military news + imagery search. Generous quota, free.
# Get at api.dvidshub.net.
# DVIDS_API_KEY=

# ============================================================
# OPTIONAL — Hill members nightly sync (separate from Scout)
# ============================================================
# Without CONGRESS_GOV_API_KEY the Hill Ops tab still works from the
# seeded snapshot data in `supabase/seed/budget/16-18_hill_*.sql`; it
# just won't auto-refresh as the Congress turns over. Get a key at
# api.congress.gov.
# CONGRESS_GOV_API_KEY=

# Congress number. Defaults to '119'. Bump when a new Congress starts.
# CONGRESS_NUMBER=119

# ============================================================
# OPTIONAL — Netlify site password protection
# ============================================================
# If your Netlify site is behind visitor-access password protection,
# the scout-background function needs the same password to call back
# into the site through the edge. Accepts either name.
# NETLIFY_SITE_PASSWORD=
# SITE_PASSWORD=
