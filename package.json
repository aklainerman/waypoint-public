{
  "name": "waypoint",
  "version": "1.0.0",
  "private": true,
  "description": "Waypoint - DoD budget + outreach CRM template. Three deploy environments (prod/stage/demo) share this single codebase via the WAYPOINT_ENV env var.",
  "scripts": {
    "dev": "netlify dev",
    "deploy:stage": "netlify deploy --alias=stage",
    "deploy:prod": "netlify deploy --prod",
    "smoke": "playwright test",
    "smoke:headed": "playwright test --headed",
    "smoke:debug": "playwright test --debug",
    "smoke:ui": "playwright test --ui",
    "smoke:report": "playwright show-report"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/reesemozer/waypoint.git"
  },
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.45.0"
  }
}
